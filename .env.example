# Mistral API
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# Gmail filtering
TARGET_RECIPIENT_EMAIL=bertrandmiannay@gmail.com

# Optional: only process emails whose sender address is on this domain
# (e.g. a contact-form relay such as brevosend.com). Leave empty to disable.
SENDER_DOMAIN_FILTER=

# Gmail OAuth credentials (paths are relative to the working directory,
# or absolute paths inside the container, e.g. /app/credentials/...)
GMAIL_CLIENT_SECRET_PATH=credentials/client_secret.json
GMAIL_TOKEN_PATH=credentials/token.json

# Reply generation
REPLY_PROMPT_PATH=prompts/reply_instructions.txt

# Dedup label applied to processed emails
PROCESSED_LABEL_NAME=AI-Processed

# Misc
LOG_LEVEL=INFO
DRY_RUN=false
